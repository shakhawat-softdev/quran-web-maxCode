{
  "name": "quran-api",
  "version": "1.0.0",
  "description": "Scalable Quran API using Hono with search, caching, and rate limiting",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "preview": "node dist/index.js",
    "serve": "npm run build && npm start",
    "lint": "eslint src || true"
  },
  "keywords": [
    "quran",
    "api",
    "hono",
    "scalable",
    "search",
    "caching",
    "rate-limiting"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "@hono/node-server": "^1.0.0",
    "@hono/swagger-ui": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
